syn/*.dcp
syn/*.bit

# Yosys intermediate artifacts
syn/lliu.json
syn/lliu_synth.v

# Vivado temp/scratch directories
syn/.Xil/
syn/.srcs/

# Vivado run logs (large/noisy; keep human-readable reports instead)
syn/reports/vivado*.log
